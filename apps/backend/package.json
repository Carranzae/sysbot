{
  "name": "@syst/backend",
  "version": "1.0.0",
  "description": "SYST Backend API - NestJS",
  "scripts": {
    "build": "prisma generate --schema=../../packages/database/prisma/schema.prisma && nest build",
    "dev": "ts-node -r tsconfig-paths/register src/main.ts",
    "dev:watch": "nest start --watch --preserveWatchOutput",
    "dev:nocheck": "nest start --watch --preserveWatchOutput --type-check false",
    "start": "node dist/main",
    "start:prod": "node dist/main",
    "prod": "pnpm run build && pnpm run start:prod",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:seed": "ts-node prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:smoke": "node scripts/test-botconfig-upsert.js",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:build": "docker-compose build",
    "health": "curl http://localhost:3000/health"
  },
  "dependencies": {
    "@apollo/server": "^4.9.5",
    "@aws-sdk/client-s3": "^3.490.0",
    "@aws-sdk/s3-request-presigner": "^3.490.0",
    "@cacheable/node-cache": "^1.7.6",
    "@google/generative-ai": "^0.24.1",
    "@hapi/boom": "^10.0.1",
    "@nestjs/apollo": "^12.0.11",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bull": "^10.0.1",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.3.0",
    "@nestjs/graphql": "^12.0.11",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/platform-socket.io": "^10.3.0",
    "@nestjs/schedule": "^6.1.0",
    "@nestjs/serve-static": "^4.0.2",
    "@nestjs/swagger": "^7.3.0",
    "@nestjs/terminus": "^10.3.0",
    "@nestjs/websockets": "^10.3.0",
    "@prisma/client": "^5.8.0",
    "@syst/ai-engine": "workspace:*",
    "@syst/database": "workspace:*",
    "@syst/shared": "workspace:*",
    "@types/sharp": "^0.32.0",
    "@whiskeysockets/baileys": "7.0.0-rc13",
    "axios": "^1.6.5",
    "bcryptjs": "^3.0.0",
    "bull": "^4.12.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "googleapis": "^169.0.0",
    "graphql": "^16.8.1",
    "imap": "^0.8.19",
    "ioredis": "^5.3.2",
    "mailparser": "^3.9.1",
    "mammoth": "^1.6.0",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "2",
    "nodemailer": "^7.0.12",
    "openai": "^4.24.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.17.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.34.5",
    "socket.io": "^4.6.0",
    "socket.io-client": "^4.6.0",
    "stripe": "^22.0.1",
    "swagger-ui-express": "^5.0.0",
    "tesseract.js": "^5.1.1",
    "twilio": "^5.0.0",
    "whatsapp-web.js": "^1.34.2",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^5.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.2.1",
    "@nestjs/schematics": "^10.0.3",
    "@nestjs/testing": "^10.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/imap": "^0.8.43",
    "@types/mailparser": "^3.4.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.6",
    "@types/passport-jwt": "^4.0.0",
    "@types/passport-local": "^1.0.38",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "pg": "^8.16.3",
    "prisma": "^5.8.0",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.6.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "webpack": "^5.107.2",
    "webpack-node-externals": "^3.0.0"
  }
}
