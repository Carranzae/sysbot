// Nuevo modelo para pagos automatizados
model AutomatedPayment {
  id            String            @id @default(uuid())
  businessId    String
  customerId    String?
  customerEmail String?
  customerPhone String?
  customerName  String?
  amount        Decimal
  currency      String            @default("PEN")
  gateway       PaymentGateway
  gatewayPaymentId String?         // ID del pago en el gateway externo
  status        PaymentStatus      @default(PENDING)
  paymentUrl    String?           // URL para completar pago
  qrCode        String?           // QR code para Yape/Plin
  metadata      Json?             // Información adicional
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  expiresAt     DateTime?         // Expiración del pago
  
  business      Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  @@index([businessId, status])
  @@index([gatewayPaymentId])
  @@map("automated_payments")
}

// Nuevo modelo para webhooks de pagos
model PaymentWebhook {
  id          String            @id @default(uuid())
  businessId  String?
  gateway     PaymentGateway
  payload     Json              // Payload completo del webhook
  signature   String?           // Firma para verificación
  processed   Boolean           @default(false)
  processedAt DateTime?
  createdAt   DateTime          @default(now())
  
  business    Business?         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  @@index([gateway, processed])
  @@map("payment_webhooks")
}

// Modelo de suscripciones para planes empresariales
model Subscription {
  id          String                @id @default(uuid())
  businessId  String
  planType    SubscriptionPlanType
  status      SubscriptionStatus    @default(ACTIVE)
  expiresAt   DateTime?
  features    String[]
  limits      Json                   // { businesses: Int, messages: Int, aiTokens: Int, calls: Int, callMinutes: Int }
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  
  business    Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  @@index([businessId, status])
  @@map("subscriptions")
}

enum SubscriptionPlanType {
  BASIC
  STANDARD
  PREMIUM
  ENTERPRISE
  ULTIMATE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  SUSPENDED
}

// ============================================
// SISTEMA DE PLANES Y SUSCRIPCIONES (5 NIVELES)
// ============================================

enum BusinessPlanType {
  FREE
  STARTER
  PROFESSIONAL
  BUSINESS
  ENTERPRISE
}

enum PlanInterval {
  MONTHLY
  YEARLY
}

enum BusinessSubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PENDING
  TRIAL
}

// Suscripción de negocio a un plan específico
model BusinessSubscription {
  id                String                    @id @default(uuid())
  businessId        String
  planId            String
  planType          BusinessPlanType          @default(FREE)
  interval          PlanInterval              @default(MONTHLY)
  status            BusinessSubscriptionStatus @default(ACTIVE)
  
  // Fechas
  startDate         DateTime                  @default(now())
  endDate           DateTime
  trialEndsAt       DateTime?
  
  // Período actual
  currentPeriodStart DateTime                 @default(now())
  currentPeriodEnd    DateTime
  
  // Cancelación
  cancelAtPeriodEnd Boolean                   @default(false)
  cancelledAt       DateTime?
  
  // Precio
  price             Decimal                   @default(0) @db.Decimal(10, 2)
  currency          String                    @default("USD")
  
  // Features habilitadas (JSON)
  enabledFeatures   Json?
  
  // Relaciones
  business          Business                  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  
  @@index([businessId, status])
  @@index([planType, status])
  @@index([currentPeriodEnd])
  @@map("business_subscriptions")
}

// ============================================
// CONVERSACIONES PARA LÍMITES DE PLAN FREE
// ============================================

model Conversation {
  id                String        @id @default(uuid())
  businessId        String
  customerPhone     String
  customerName      String?
  
  // Contadores
  messageCount      Int           @default(0)
  
  // Estado
  status            String        @default("ACTIVE") // ACTIVE, CLOSED, ARCHIVED
  
  // Última actividad
  lastMessageAt     DateTime?
  lastMessageBy     String?       // BUSINESS o CUSTOMER
  
  // Relaciones
  business          Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  chatMessages      ChatMessage[]
  
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  
  @@index([businessId, createdAt])
  @@index([businessId, status])
  @@index([customerPhone])
  @@map("conversations")
}

// Mensajes dentro de una conversación
model ChatMessage {
  id              String          @id @default(uuid())
  conversationId  String
  
  // Contenido
  content         String?
  mediaUrl        String?
  mediaType       String?         // image, video, audio, document
  
  // Dirección
  direction       String          // INBOUND o OUTBOUND
  sentBy          String          // BUSINESS o CUSTOMER
  
  // Estado
  status          String          @default("SENT") // SENT, DELIVERED, READ, FAILED
  
  // Timestamps
  sentAt          DateTime        @default(now())
  deliveredAt     DateTime?
  readAt          DateTime?
  
  // Relación
  conversation    Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  @@index([conversationId, sentAt])
  @@map("chat_messages")
}

