// 📞 Registro CRM de Llamadas y "Escucha Activa"
model CallLog {
  id                String       @id @default(uuid())
  businessId        String
  contactId         String
  duration          Int          // Duración en segundos
  status            CallStatus   @default(COMPLETED) // COMPLETED, MISSED, BUSY, FAILED
  recordingUrl      String?      // URL de la grabación para Escucha Activa
  transcription     String?      @db.Text
  sentimentAnalysis String?      // Análisis de humor (ANGRY, NEUTRAL, HAPPY, etc.)
  queryResolved     Boolean      @default(false) // Si el bot resolvió la duda del cliente
  crmTaskCreated    Boolean      @default(false) // Si se asignó tarea automática
  surveyScore       Int?         // Calificación final del bot (1 a 5)
  surveyFeedback    String?      // Feedback cualitativo
  createdAt         DateTime     @default(now())
  
  business          Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  contact           Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([contactId])
  @@map("call_logs")
}

enum CallStatus {
  COMPLETED
  MISSED
  BUSY
  FAILED
}

// 🧠 Memoria de Aprendizaje Diario ("Estudiante Virtual")
model DailyLearningLog {
  id                String       @id @default(uuid())
  businessId        String
  logDate           DateTime     @default(now())
  analyzedTickets   Int          // Cantidad de tickets analizados
  criticalIssues    Json         // Lista de fallas críticas detectadas en el servicio
  optimizedRagCount Int          // Cuántos conocimientos del RAG se ajustaron/mejoraron
  insights          String       @db.Text // Conclusiones del estudiante virtual
  performanceScore  Decimal      @db.Decimal(5, 2) // Calificación de efectividad diaria (0-100)
  createdAt         DateTime     @default(now())

  business          Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, logDate])
  @@map("daily_learning_logs")
}

// 🛡️ Lista de IPs y Teléfonos Bloqueados (Prevención de Fraudes e Inyecciones)
model SecurityBlocklist {
  id                String       @id @default(uuid())
  businessId        String
  targetType        BlockType    // IP, PHONE, EMAIL
  targetValue       String       // La dirección IP o número telefónico bloqueado
  reason            String       // Razón del bloqueo
  severity          BlockSeverity @default(HIGH)
  blockedAt         DateTime     @default(now())
  expiresAt         DateTime?

  business          Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, targetValue])
  @@map("security_blocklist")
}

enum BlockType {
  IP
  PHONE
  EMAIL
}

enum BlockSeverity {
  MEDIUM
  HIGH
  CRITICAL
}

