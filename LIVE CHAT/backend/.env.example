# Variables de entorno para LAY CHAT Backend
# Copia este archivo como .env y completa los valores

# ─── BASE DE DATOS ────────────────────────────────────────────────
DATABASE_URL=postgresql://usuario:password@localhost:5432/laychat
DATABASE_SSL=false

# ─── SERVIDOR ────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── AUTENTICACIÓN JWT ───────────────────────────────────────────
JWT_SECRET=tu_secreto_jwt_aqui_cambialo

# ─── REDIS (para caché) ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── IA (opcional — para el bot automático) ──────────────────────
GEMINI_API_KEY=tu_clave_gemini_aqui
GROQ_API_KEY=tu_clave_groq_aqui

# ─── META WHATSAPP BUSINESS API (opcional) ───────────────────────
META_WABA_TOKEN=
META_WABA_PHONE_NUMBER_ID=
META_WABA_WEBHOOK_VERIFY_TOKEN=laychat_secret
